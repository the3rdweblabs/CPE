# vault-dapp environment variables


# Required - get a free project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Active Network configuration ('sepolia' or 'mainnet')
VITE_NETWORK=sepolia

# Optional - Infura key for a more reliable Sepolia RPC endpoint.
VITE_INFURA_API_KEY=

# Contract addresses (Sepolia deployment)
# These are public on-chain addresses
# Pre-filled with the current live deployment; update only if you redeploy.
VITE_ADDR_VAULT=0xE2F5a96D3C2901085B4106fff07c7A39D88C06D1
VITE_ADDR_CPE=0x83Cf96bcfDaD84ee0c0B222Ee9BcE89DfE41C59c
VITE_ADDR_GATEWAY=0x78FBB8A0134f189DD016C7F778f44b1ecbe7AAb6
VITE_ADDR_REGISTRY=0xB0B2a558975be15B145E3451d8A16227CcFf914B
VITE_ADDR_LOGGER=0x4574d5F4a25AD9231f2a8Cb9454737DAd3461Db3
VITE_ADDR_DAO=0xfeE66FEAe898CBb241d55dAb6526c1b43c068237
VITE_ADDR_DAO_FACTORY=0xAa3Fe2eFaFC2EFBB8019B9255Cf8A5136563635D
