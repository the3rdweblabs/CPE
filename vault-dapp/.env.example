# vault-dapp environment variables


# Required - get a free project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Active Network configuration ('sepolia' or 'mainnet')
VITE_NETWORK=sepolia

# Optional - Infura key for a more reliable Sepolia RPC endpoint.
VITE_INFURA_API_KEY=

# Contract addresses (Sepolia deployment)
# These are public on-chain addresses
# Pre-filled with the current live deployment; update only if you redeploy.
VITE_ADDR_VAULT=0xE72FccA450A9a0e4EBC1e61A38DC31c481Cff98c
VITE_ADDR_CPE=0x7843ACB0d148e8D5d914ab6c040C50e4eE115d39
VITE_ADDR_GATEWAY=0x69cc375f1f0F65234fD1309442516BdBd6043429
VITE_ADDR_REGISTRY=0x6FFBDcFF78B4C9828d3B31b5EEbf13644DEf210d
VITE_ADDR_LOGGER=0xfA0DD0a1Ba7C6C0FaD50fb22961c9AB0db88b614
VITE_ADDR_DAO=0x55112E95366721b709Afc8fA343747EEf6c3a2ca
VITE_ADDR_DAO_FACTORY=0x17493E2Cab0676F50b6aB0b3436de6e47F0E47C3