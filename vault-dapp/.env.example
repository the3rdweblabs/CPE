# vault-dapp environment variables
# Copy this file to .env and fill in your values.

# Required - get a free project ID from https://cloud.walletconnect.com
# (RainbowKit uses WalletConnect under the hood)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional - Infura key for a more reliable Sepolia RPC endpoint.
# If left empty the app falls back to the public endpoint.
VITE_INFURA_API_KEY=

# Contract addresses
# These are public on-chain addresses - NOT secrets.
# Pre-filled with the current live deployment; update only if you redeploy.
VITE_ADDR_VAULT=vault-address
VITE_ADDR_CPE=cpe-addres
VITE_ADDR_GATEWAY=gateway-address
VITE_ADDR_REGISTRY=registry-address
VITE_ADDR_LOGGER=logger-address