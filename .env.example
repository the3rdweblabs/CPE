# Example .env file for relayer-sdk CLI and quick local testing
# Copy to .env.testnet or .env.devnet as needed and fill values.

# Wallet mnemonic (12 words) - ONLY use a test mnemonic here
MNEMONIC="test test test test test test test test test test test junk"

# RPC provider URL (Sepolia example)
RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Relayer URL - point to the relayer you want to use
RELAYER_URL="https://relayer.testnet.zama.org/v2"

# Optional Zama API key (required for Mainnet relayer)
ZAMA_FHEVM_API_KEY=""

# Contract addresses (optional) - used by relayer CLI when not provided via options
# CONTRACT_ADDRESS="0x..."
# ACL_CONTRACT_ADDRESS="0x..."
# KMS_VERIFIER_CONTRACT_ADDRESS="0x..."
# INPUT_VERIFIER_CONTRACT_ADDRESS="0x..."
# INPUT_VERIFICATION_ADDRESS="0x..."
# DECRYPTION_ADDRESS="0x..."
